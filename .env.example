# JWT_SECRET: Secret for signing JWT tokens
JWT_SECRET="YOUR_JWT_SECRET_HERE"

# DATABASE_URL: MySQL connection string
# Example: mysql://user:password@localhost:3306/segagenda?connection_limit=2&pool_timeout=20
DATABASE_URL="mysql://user:pass@host:port/db?connection_limit=2&pool_timeout=20"

# Server Configuration
PORT=3000
NODE_ENV=production
APP_URL="https://agenda.segnorte.com.br"

# SMTP Configuration (Email)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_SECURE="false"
